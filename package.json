{
  "name": "mavi",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --filter @mavi/web dev",
    "dev:server": "bun run --filter @mavi/server dev",
    "build": "bun run --filter '*' build",
    "build:web": "bun run --filter @mavi/web build",
    "build:server": "bun run --filter @mavi/server build",
    "test": "bun run --filter '*' test",
    "test:e2e": "bun run --filter @mavi/web test:e2e",
    "knip": "knip",
    "lint": "oxlint --deny-warnings .",
    "lint:ts": "bun run --filter '*' lint:ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "knip": "~5.85.0",
    "oxfmt": "~0.35.0",
    "oxlint": "~1.50.0",
    "typescript": "~5.9.3",
    "vite": "~7.3.1",
    "vitest": "~4.0.18"
  },
  "engines": {
    "bun": "1.3.9",
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
